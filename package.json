{
  "name": "serene",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun run --cwd apps/web dev",
    "build": "bun run --cwd apps/web build",
    "start": "bun run --cwd apps/web start",
    "check": "bun run lint && bun run format:check && bun run typecheck && bun run test",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "tsc -p apps/web --noEmit && tsc -p packages/core --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@evilmartians/lefthook": "^1.7.0",
    "@types/node": "^22.0.0",
    "oxfmt": "latest",
    "oxlint": "latest",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
