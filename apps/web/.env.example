# serene v0.1 environment variables

# Required: AES-256 key for encrypting source credentials at rest.
# Generate with: openssl rand -base64 32
SERENE_ENCRYPTION_KEY=

# Optional: SQLite file path. Defaults to ./data/serene.db
SERENE_DB_PATH=./data/serene.db

# Optional: pin the owner UUID. Generated on first run if missing.
# SERENE_OWNER_ID=

# Optional: skip the in-process sync scheduler (useful in tests/CI).
# SERENE_DISABLE_SYNC=1

# WHOOP OAuth — register a developer app at https://developer.whoop.com
# WHOOP_CLIENT_ID=
# WHOOP_CLIENT_SECRET=
# WHOOP_REDIRECT_URI=http://localhost:3001/api/auth/whoop/callback
