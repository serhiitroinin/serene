{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "react", "import", "unicorn"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "no-console": "warn",
    "react/react-in-jsx-scope": "off",
    "import/no-unassigned-import": "off"
  },
  "ignorePatterns": [
    "**/dist/**",
    "**/build/**",
    "**/.output/**",
    "**/.tanstack/**",
    "**/node_modules/**",
    "**/routeTree.gen.ts",
    "**/.vite/**",
    "**/coverage/**"
  ]
}
